# -----------------------------------------------------------------------------
# Plantilla de Configuración del Entorno - FintechOS
# Copia este archivo como '.env' y rellena tus propias llaves/credenciales
# -----------------------------------------------------------------------------

# Entorno de Django (True para desarrollo, False para producción)
DEBUG=True
SECRET_KEY=django-insecure-tu-clave-secreta-aqui

# -----------------------------------------------------------------------------
# BASE DE DATOS: PostgreSQL (Supabase)
# -----------------------------------------------------------------------------
DB_NAME=postgres
DB_USER=tu_usuario_de_supabase
DB_PASSWORD=tu_contrasena_de_supabase
DB_HOST=tu_host_de_supabase_pooler.supabase.com
DB_PORT=6543
DATABASE_URL=postgresql://tu_usuario:tu_contrasena@tu_host:6543/postgres

# -----------------------------------------------------------------------------
# INTEGRACIONES SANDBOX (APIs)
# -----------------------------------------------------------------------------
# Llaves de prueba de Stripe
STRIPE_PUBLIC_KEY=pk_test_tu_llave_publica_aqui
STRIPE_SECRET_KEY=sk_test_tu_llave_privada_aqui

# Credenciales Sandbox de Facturapi / Finkargo
FACTURAPI_API_KEY=sk_test_tu_llave_facturapi_aqui
